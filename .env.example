# --- Bidding microservice ---

# Run fully mocked (canned AI checklist + local-temp blob + local SQLite).
# Default is ON so the service is demoable with zero external dependencies.
BIDDING_MOCK=1

# Isolated database. Leave unset for the local SQLite fallback (dev/tests).
# PRODUCTION: a DEDICATED Azure SQL server, separate from the shared one, with
# its own credential in Key Vault (this service stores GDPR special-category
# documents and must not share a DB with the other services).
# DATABASE_URL=mssql+aioodbc://bidadmin:<secret>@sql-bidding-xx.database.windows.net:1433/bidding?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes

# Azure Blob for original documents (mock backend used when BIDDING_MOCK=1).
# BIDDING_BLOB_CONNECTION_STRING=
BIDDING_BLOB_CONTAINER=bid-documents

# ai-connector (used only when BIDDING_MOCK=0).
AI_URL=http://ai:8004

ALLOWED_ORIGINS=http://localhost:8009
